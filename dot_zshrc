export EDITOR=vim
export VISUAL=vim

source <(fzf --zsh)
eval "$(zoxide init zsh)"
eval "$(mise activate zsh)"
eval "$(starship init zsh)"

# eza (modern ls replacement)
alias ls='eza'
alias ll='eza -lah --icons --git'
alias lt='eza --tree --level=2'

# chezmoi dotfiles sync
alias dotsync='brew bundle dump --global --force && chezmoi re-add && git -C "$(chezmoi source-path)" add -A && git -C "$(chezmoi source-path)" commit -m "sync dotfiles $(date +%Y-%m-%d)" && git -C "$(chezmoi source-path)" push'

# TinyTeX
export PATH="$HOME/Library/TinyTeX/bin/universal-darwin:$PATH"

# OpenClaw Completion
source "/Users/rob/.openclaw/completions/openclaw.zsh"
